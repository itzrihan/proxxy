{
  "version": 2,
  "routes": [
    {
      "src": "/proxy(.*)",
      "dest": "/api/proxy"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index"
    }
  ],
  "headers": [
    {
      "source": "/proxy/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS, PATCH, HEAD" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, Range, Origin" }
      ]
    }
  ]
}
